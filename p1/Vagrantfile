Vagrant.configure('2') do |config|
  config.vm.box = 'generic/alpine319'

  nodes.each do |nodo|
    config.vm.define nodo[:nombre] do |machine|
      machine.vm.hostname = nodo[:nombre]
<<<<<<< Updated upstream
      machine.vm.network 'private_network', ip: nodo[:network_address]
=======
       machine.vm.network 'private_network', ip: nodo[:network_address]
